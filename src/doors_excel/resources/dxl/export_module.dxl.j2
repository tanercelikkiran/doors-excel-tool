// export_module.dxl.j2 — rendered by Jinja2; do not edit manually.
// Exports all objects from module {{ module_path | dxl_value }}.
//
// Output format per object (FS = \x1f, RS = \x1e):
//   abs_no FS level FS parent_abs_no FS has_ole FS
//   obj_type FS parent_absno FS row_pos FS col_pos FS
//   [plain FS rtf FS]... RS \n
//
// TABLE_ROW and TABLE_CELL have abs_no=0; they get synthetic IDs on the Python side.
// TABLE_END rows are injected by Python after parsing; DXL does not emit them.

string FS = "\x1f"
string RS  = "\x1e"

int curTableAbsNo = 0
int curRowPos     = 0
int curColPos     = 0

Module m = read("{{ module_path | dxl_value }}", false)
if null m then {
    print "DOORS_EXPORT_ERROR: Cannot open module {{ module_path | dxl_value }}\n"
    halt
}

Object o
for o in entire m do {
    int an = absNo(o)

    string objType  = "OBJECT"
    int parentAbsNo = 0
    int rowPos      = 0
    int colPos      = 0

    if isTable(o) then {
        objType = "TABLE"
        curTableAbsNo = an
        curRowPos = 0
        curColPos = 0
    } else if isTableRow(o) then {
        objType = "TABLE_ROW"
        curRowPos = curRowPos + 1
        curColPos = 0
        parentAbsNo = curTableAbsNo
        rowPos = curRowPos
    } else if isTableCell(o) then {
        objType = "TABLE_CELL"
        curColPos = curColPos + 1
        parentAbsNo = curTableAbsNo
        rowPos = curRowPos
        colPos = curColPos
    } else if an == 0 then {
        continue
    }

    string sParent = ""
    Object par = parent(o)
    if !null par then { sParent = absNo(par) "" }

    // OLE detection
    int hasOleFlag = 0
    {
        OleItem item
        for item in o do { hasOleFlag = 1; break }
    }

    print an "" FS
    print level(o) "" FS
    print sParent FS
    print hasOleFlag "" FS
    print objType FS
    print parentAbsNo "" FS
    print rowPos "" FS
    print colPos "" FS

{% for attr in attributes %}
    {
        string p{{ loop.index }} = o."{{ attr | dxl_value }}"
        if undefined p{{ loop.index }} then { p{{ loop.index }} = "" }
        string r{{ loop.index }} = richText(o, "{{ attr | dxl_value }}")
        if undefined r{{ loop.index }} then { r{{ loop.index }} = "" }
        print p{{ loop.index }} FS r{{ loop.index }} FS
    }
{% endfor %}
    print RS "\n"
}
close(m)
